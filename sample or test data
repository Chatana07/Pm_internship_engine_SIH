def test_api_endpoints(base_url='http://localhost:5000'):
    """Test API endpoints"""
    print(f"\n=== Testing API Endpoints at {base_url} ===")
    
    # Test health endpoint
    try:
        response = requests.get(f"{base_url}/api/health", timeout=5)
        print(f"Health Check: {response.status_code} - {response.json()}")
    except Exception as e:
        print(f"Health Check Failed: {e}")
        return False
    
    # Test sectors endpoint
    try:
        response = requests.get(f"{base_url}/api/sectors", timeout=5)
        print(f"Sectors: {response.status_code} - Found {len(response.json()['sectors'])} sectors")
    except Exception as e:
        print(f"Sectors endpoint failed: {e}")
    
    # Test recommendations endpoint
    test_candidate = {
        'age': 22,
        'education': 'B.Tech Computer Science',
        'skills': 'Python, JavaScript, web development',
        'interests': 'software development, programming',
        'preferred_sector': 'Technology',
        'preferred_location': 'Bangalore',
        'family_income': 600000,
        'is_employed': False,
        'govt_employee_family': False
    }
    
    try:
        response = requests.post(
            f"{base_url}/api/recommendations",
            json=test_candidate,
            timeout=10
        )
        result = response.json()
        print(f"Recommendations: {response.status_code}")
        
        if result['success'] and result['data']['eligible']:
            print(f"  Found {len(result['data']['recommendations'])} recommendations")
            for rec in result['data']['recommendations']:
                print(f"    - {rec['title']} (Score: {rec['match_score']}%)")
        else:
            print(f"  Issues: {result['data']['issues']}")
            
    except Exception as e:
        print(f"Recommendations endpoint failed: {e}")
    
    # Test validation endpoint
    try:
        response = requests.post(
            f"{base_url}/api/validate",
            json=test_candidate,
            timeout=5
        )
        result = response.json()
        print(f"Validation: {response.status_code} - Eligible: {result['eligible']}")
    except Exception as e:
        print(f"Validation endpoint failed: {e}")
    
    return True

def performance_test():
    """Test system performance"""
    print("\n=== Performance Testing ===")
    
    engine = PMInternshipRecommendationEngine()
    engine.load_internship_data('sample_internships_dataset.csv')
    engine.preprocess_internships()
    
    test_candidate = {
        'age': 22,
        'education': 'B.Tech',
        'skills': 'Python, web development',
        'interests': 'technology',
        'preferred_sector': 'Technology',
        'preferred_location': 'Bangalore',
        'family_income': 500000,
        'is_employed': False,
        'govt_employee_family': False
    }
    
    # Test multiple requests
    times = []
    for i in range(10):
        start_time = time.time()
        recommendations = engine.get_recommendations(test_candidate, top_k=5)
        end_time = time.time()
        times.append(end_time - start_time)
    
    avg_time = sum(times) / len(times)
    print(f"Average response time: {avg_time:.3f} seconds")
    print(f"Min time: {min(times):.3f}s, Max time: {max(times):.3f}s")
    
    if avg_time < 1.0:
        print("✓ Performance is good (< 1 second)")
    elif avg_time < 3.0:
        print("⚠ Performance is acceptable (< 3 seconds)")
    else:
        print("✗ Performance needs improvement (> 3 seconds)")

