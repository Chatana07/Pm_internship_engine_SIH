# Additional utility functions for testing

def create_load_test_data(num_candidates=100):
    """Generate load test data"""
    import random
    
    sectors = ['Technology', 'Finance', 'Marketing', 'Healthcare', 'Education']
    locations = ['Mumbai', 'Delhi', 'Bangalore', 'Chennai', 'Hyderabad']
    educations = ['B.Tech', 'BBA', 'B.Com', 'B.Sc', 'BCA']
    
    candidates = []
    for i in range(num_candidates):
        candidate = {
            'age': random.randint(21, 24),
            'education': random.choice(educations),
            'skills': 'communication, teamwork, problem solving',
            'interests': f'{random.choice(sectors).lower()}, learning',
            'preferred_sector': random.choice(sectors),
            'preferred_location': random.choice(locations),
            'family_income': random.randint(200000, 700000),
            'is_employed': False,
            'govt_employee_family': False
        }
        candidates.append(candidate)
    
    with open('load_test_candidates.json', 'w') as f:
        json.dump(candidates, f, indent=2)
    
    print(f"Generated {num_candidates} test candidates")
    return candidates

def validate_csv_format(csv_path):
    """Validate if CSV has required format"""
    try:
        df = pd.read_csv(csv_path)
        required_columns = ['title', 'company', 'sector', 'location', 'description']
        missing_columns = [col for col in required_columns if col not in df.columns]
        
        if missing_columns:
            print(f"Missing required columns: {missing_columns}")
            return False
        
        print(f"CSV format validation: PASSED")
        print(f"Found {len(df)} internships with all required columns")
        return True
        
    except Exception as e:
        print(f"CSV validation failed: {e}")
        return False