@app.route('/api/recommendations', methods=['POST'])
def get_recommendations():
    """Main endpoint to get internship recommendations"""
    try:
        if not model_loaded:
            return jsonify({
                'error': 'Model not loaded. Please contact administrator.',
                'success': False
            }), 500
        
        # Get request data
        data = request.get_json()
        
        if not data:
            return jsonify({
                'error': 'No data provided',
                'success': False
            }), 400
        
        # Validate required fields
        required_fields = ['age', 'education', 'family_income']
        missing_fields = [field for field in required_fields if field not in data]
        
        if missing_fields:
            return jsonify({
                'error': f'Missing required fields: {", ".join(missing_fields)}',
                'success': False
            }), 400
        
        # Prepare candidate profile
        candidate_profile = {
            'age': data.get('age', 0),
            'education': data.get('education', ''),
            'skills': data.get('skills', ''),
            'interests': data.get('interests', ''),
            'preferred_sector': data.get('preferred_sector', ''),
            'preferred_location': data.get('preferred_location', ''),
            'family_income': data.get('family_income', 0),
            'is_employed': data.get('is_employed', False),
            'govt_employee_family': data.get('govt_employee_family', False)
        }
        
        # Get number of recommendations (default 5, max 10)
        top_k = min(data.get('top_k', 5), 10)
        
        # Get recommendations from engine
        recommendations = recommendation_engine.get_recommendations(
            candidate_profile, 
            top_k=top_k
        )
        
        # Log the request (anonymized)
        logger.info(f"Recommendation request - Age: {candidate_profile['age']}, "
                   f"Sector: {candidate_profile['preferred_sector']}, "
                   f"Location: {candidate_profile['preferred_location']}")
        
        return jsonify({
            'success': True,
            'data': recommendations,
            'timestamp': datetime.now().isoformat()
        })
        
    except Exception as e:
        logger.error(f"Error processing recommendation request: {e}")
        return jsonify({
            'error': 'Internal server error',
            'success': False,
            'details': str(e) if app.debug else None
        }), 500

@app.route('/api/validate', methods=['POST'])
def validate_candidate():
    """Validate candidate eligibility without recommendations"""
    try:
        if not model_loaded:
            return jsonify({
                'error': 'Model not loaded',
                'success': False
            }), 500
        
        data = request.get_json()
        
        if not data:
            return jsonify({
                'error': 'No data provided',
                'success': False
            }), 400
        
        candidate_profile = {
            'age': data.get('age', 0),
            'education': data.get('education', ''),
            'family_income': data.get('family_income', 0),
            'is_employed': data.get('is_employed', False),
            'govt_employee_family': data.get('govt_employee_family', False)
        }
        
        # Check eligibility
        is_eligible, issues = recommendation_engine.check_eligibility(candidate_profile)
        
        return jsonify({
            'success': True,
            'eligible': is_eligible,
            'issues': issues,
            'message': 'Eligible for PM Internship Scheme' if is_eligible else 'Not eligible - see issues'
        })
        
    except Exception as e:
        logger.error(f"Error validating candidate: {e}")
        return jsonify({
            'error': 'Internal server error',
            'success': False
        }), 500

@app.route('/api/feedback', methods=['POST'])
def submit_feedback():
    """Collect feedback on recommendations (for future improvements)"""
    try:
        data = request.get_json()
        
        # Save feedback to file (in production, use a database)
        feedback = {
            'timestamp': datetime.now().isoformat(),
            'internship_id': data.get('internship_id'),
            'rating': data.get('rating'),
            'feedback': data.get('feedback'),
            'applied': data.get('applied', False)
        }
        
        # Write to feedback file
        feedback_file = 'feedback.jsonl'
        with open(feedback_file, 'a') as f:
            f.write(json.dumps(feedback) + '\n')
        
        logger.info(f"Feedback received for internship {feedback['internship_id']}")
        
        return jsonify({
            'success': True,
            'message': 'Feedback submitted successfully'
        })
        
    except Exception as e:
        logger.error(f"Error submitting feedback: {e}")
        return jsonify({
            'error': 'Failed to submit feedback',
            'success': False
        }), 500

