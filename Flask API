# Flask API for PM Internship Recommendation System
from flask import Flask, request, jsonify, render_template_string
from flask_cors import CORS
import json
import os
from datetime import datetime
import logging

# Import our recommendation engine
from pm_internship_engine import PMInternshipRecommendationEngine

app = Flask(__name__)
CORS(app)  # Enable CORS for frontend integration

# Configure logging
logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)

# Initialize recommendation engine
recommendation_engine = PMInternshipRecommendationEngine()

# Global variable to track if model is loaded
model_loaded = False

def initialize_model():
    """Initialize the recommendation model with data"""
    global model_loaded
    try:
        # Load your internship dataset CSV file here
        csv_file = 'internships_dataset.csv'  # Replace with your actual CSV file path
        
        if os.path.exists(csv_file):
            recommendation_engine.load_internship_data(csv_file)
            recommendation_engine.preprocess_internships()
            model_loaded = True
            logger.info("Model initialized successfully")
        else:
            logger.error(f"CSV file {csv_file} not found")
    except Exception as e:
        logger.error(f"Error initializing model: {e}")

